# Copiar a /opt/va-bus/backend/.env en el servidor y rellenar.
# NUNCA subir el .env real a git (ya está ignorado).

# ── Django ──
DEBUG=False
SECRET_KEY=GENERA-UNA-CLAVE-LARGA-Y-ALEATORIA
ALLOWED_HOSTS=aerorutasdevenezuela.net,localhost,127.0.0.1

# ── PostgreSQL administrada (DigitalOcean) ──
# Usá el host de la pestaña "VPC network" si el droplet está en la misma VPC.
DB_NAME=defaultdb
DB_USER=doadmin
DB_PASSWORD=PON-AQUI-LA-PASSWORD-DE-LA-DB
DB_HOST=dbaas-db-1243321-do-user-35115103-0.i.db.ondigitalocean.com
DB_PORT=25060
DB_SSLMODE=require

# ── Google OAuth ──
GOOGLE_CLIENT_ID=

# ── Email (Gmail SMTP) ──
# EMAIL_HOST_USER: el Gmail DE LA EMPRESA (no el de desarrollo).
# EMAIL_HOST_PASSWORD: App Password de Google (16 letras) — NO la contraseña
#   normal. Se genera en: Cuenta de Google → Seguridad → Verificación en 2
#   pasos → Contraseñas de aplicaciones. Requiere tener 2FA activado.
# DEFAULT_FROM_EMAIL: debe coincidir con la cuenta que envía; un dominio
#   inexistente (noreply@...) manda todo a spam.
# Diagnóstico: venv/bin/python scripts/probar_correos.py correo@destino
EMAIL_HOST_USER=aerorutasdevenezuela@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Aerorutas de Venezuela <aerorutasdevenezuela@gmail.com>
# Si el puerto 587 está bloqueado por el proveedor, probar:
# EMAIL_PORT=465
# EMAIL_USE_SSL=true

# ── Integraciones ──
EXTERNAL_API_KEY=
R4_COMMERCE_TOKEN=
AERORUTAS_API_TOKEN=
